# Standardize line endings to LF (Unix/Linux)
# All source and text files use LF
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Configuration files
.gitattributes text eol=lf
.gitignore text eol=lf
.npmrc text eol=lf
.prettierrc text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
